{
  "model": "qwen:7b",
  "provider": "ollama",
  "ai_backend": "gemini",
  "ollama_endpoint": "http://localhost:11434/api/generate",
  "source_language": "Chinese",
  "target_language": "Burmese",
  "supported_source_languages": [
    "Chinese",
    "Chinese (Simplified)",
    "Chinese (Traditional)",
    "English"
  ],
  "chunk_size": 1000,
  "chunk_overlap": 100,
  "stream": true,
  "preview_update_every_n_tokens": 10,
  "request_timeout": 900,
  "web_ui_port": 5000,
  "auto_open_browser": true,
  
  "translation_modes": {
    "description": "Three modes available: local (no limits), cloud (API with rate limits), auto (detect best)",
    "local": {
      "script": "local_main.py",
      "description": "Use local Ollama - no rate limits, faster for bulk translation",
      "default_model": "ollama:qwen2.5:14b",
      "chunk_size": 1000,
      "request_delay": 0.0,
      "rate_limits": "None (local)"
    },
    "cloud": {
      "script": "cloud_main.py",
      "description": "Use cloud APIs - rate limits apply, good for occasional use",
      "providers": {
        "gemini": {
          "default_model": "gemini-2.5-flash",
          "rpm": 15,
          "request_delay": 6.0,
          "env_key": "GEMINI_API_KEY"
        },
        "openrouter": {
          "default_model": "google/gemini-2.0-flash-exp:free",
          "rpm": 20,
          "request_delay": 5.0,
          "env_key": "OPENROUTER_API_KEY"
        }
      }
    },
    "auto": {
      "script": "main.py",
      "description": "Auto-detect: Use Ollama if available, otherwise cloud API",
      "priority": ["ollama", "gemini", "openrouter"]
    }
  },
  
  "supported_models": {
    "ollama": [
      "qwen:7b",
      "qwen2.5:7b",
      "qwen2.5:14b",
      "translategemma",
      "translategemma:12b",
      "kimi-k2.6:cloud",
      "gemma:7b"
    ],
    "openrouter": [
      "meta-llama/llama-3.3-70b-instruct:free",
      "google/gemini-2.0-flash-exp:free",
      "google/gemini-2.5-flash-exp:free",
      "deepseek/deepseek-chat:free",
      "qwen/qwen-2.5-72b-instruct:free"
    ],
    "gemini": [
      "gemini-2.5-flash",
      "gemini-2.0-flash",
      "gemini-1.5-flash",
      "gemini-1.5-pro"
    ],
    "nllb": [
      "nllb-200-distilled-600M",
      "nllb-200-1.3B",
      "nllb-200-3.3B",
      "nllb-200-distilled-1.3B"
    ]
  },
  
  "myanmar_readability": {
    "enabled": true,
    "min_myanmar_ratio": 0.7,
    "flag_on_fail": true,
    "block_on_fail": false
  },
  
  "translation_pipeline": {
    "mode": "single_stage",
    "description": "single_stage or two_stage. Two-stage uses raw translation + rewrite for better quality.",
    "stage1_model": "ollama:qwen:7b",
    "stage1_description": "Model for Stage 1 (raw translation). Options: nllb, gemini, openrouter, ollama, or ollama:modelname (e.g., ollama:gemma:7b)",
    "stage2_model": "ollama:gemma:7b",
    "stage2_description": "Model for Stage 2 (rewrite). Options: ollama (qwen), openrouter, gemini, or ollama:modelname (e.g., ollama:qwen:7b)"
  },
  
  "rate_limits": {
    "gemini": {
      "free_tier": {
        "rpm": 15,
        "tpm": 1000000,
        "recommended_delay": 6.0,
        "note": "15 requests per minute, 1 million tokens per minute"
      }
    },
    "openrouter": {
      "free_tier": {
        "rpm": 20,
        "rpd": 200,
        "recommended_delay": 5.0,
        "note": "20 requests per minute, 200 per day"
      }
    }
  }
}
