{
  "model": "qwen:7b",
  "provider": "ollama",
  "ai_backend": "ollama",
  "ollama_endpoint": "http://localhost:11434/api/generate",
  "source_language": "Chinese",
  "target_language": "Burmese",
  "supported_source_languages": [
    "Chinese",
    "Chinese (Simplified)",
    "Chinese (Traditional)",
    "English"
  ],
  "chunk_size": 1000,
  "chunk_overlap": 100,
  "stream": true,
  "preview_update_every_n_tokens": 10,
  "request_timeout": 900,
  "web_ui_port": 5000,
  "auto_open_browser": true,
  "supported_models": {
    "ollama": [
      "qwen:7b",
      "translategemma",
      "translategemma:12b",
      "kimi-k2.6:cloud"
    ],
    "openrouter": [
      "meta-llama/llama-3.3-70b-instruct:free",
      "google/gemini-2.0-flash-exp:free",
      "deepseek/deepseek-chat:free",
      "qwen/qwen-2.5-72b-instruct:free"
    ],
    "gemini": [
      "gemini-2.0-flash",
      "gemini-1.5-flash"
    ],
    "nllb": [
      "nllb-200-distilled-600M",
      "nllb-200-1.3B",
      "nllb-200-3.3B",
      "nllb-200-distilled-1.3B"
    ]
  },
  "myanmar_readability": {
    "enabled": true,
    "min_myanmar_ratio": 0.7,
    "flag_on_fail": true,
    "block_on_fail": false
