    "stage1_model": "nllb",
    "stage1_description": "Model for Stage 1 (raw translation). Options: nllb, gemini, openrouter, ollama, or ollama:modelname (e.g., ollama:gemma:7b)",
    "stage2_model": "ollama:qwen:7b",
    "stage2_description": "Model for Stage 2 (rewrite). Options: ollama (qwen), openrouter, gemini, or ollama:modelname (e.g., ollama:qwen:7b)"
  }
