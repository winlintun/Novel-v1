# =============================================================================
# Novel Translator - Git Ignore File
# =============================================================================

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual Environments ─────────────────────────────────────────────────────
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# ── IDE & Editors ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ── Project Specific: Working Data ───────────────────────────────────────────
# All working_data contents (except .gitkeep)
working_data/*
!working_data/.gitkeep
working_data/checkpoints/*
!working_data/checkpoints/.gitkeep
working_data/chunks/*
!working_data/chunks/.gitkeep
working_data/translated_chunks/*
!working_data/translated_chunks/.gitkeep
working_data/preview/*
!working_data/preview/.gitkeep
working_data/readability_reports/*
!working_data/readability_reports/.gitkeep
working_data/logs/*
!working_data/logs/.gitkeep
working_data/clean/*
!working_data/clean/.gitkeep

# ── Project Specific: Input/Output ────────────────────────────────────────────
# Input novels (user files - don't commit)
input_novels/*.txt
input_novels/*.md
!input_novels/.gitkeep

# Translated output (generated files)
translated_novels/*.md
!translated_novels/.gitkeep

# Chinese chapters (generated from extraction)
chinese_chapters/*/
!chinese_chapters/.gitkeep

# Data files
data_file/*.txt
data_file/*.md
!data_file/.gitkeep

# ── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# ── Misc ─────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
*.patch
*.diff
*.err
*.out

# ── Jupyter Notebook ─────────────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Type Checkers ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/

# ── PyInstaller ─────────────────────────────────────────────────────────────
*.manifest
*.spec

# ── Cython ───────────────────────────────────────────────────────────────────
*.pyx
*.pxd
*.pxi

# ── Opencode ─────────────────────────────────────────────────────────────────
.opencode/
