# ============================================================
# Novel Translator - AI Model Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# Only fill the key for the model you want to use!

# ------------------------------------------------------------
# CHOOSE YOUR MODEL (uncomment one):
# Options: gemini, deepseek, qwen, OpenCode
# ------------------------------------------------------------
AI_MODEL=gemini

# ------------------------------------------------------------
# GEMINI (Google AI Studio - FREE)
# Get key: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=AIzaSyBjJoGOpsPMO0qTZegU7U0tb6A6ogKIJ7s
GEMINI_MODEL=gemini-2.0-flash

# ------------------------------------------------------------
# DEEPSEEK (FREE at chat.deepseek.com)
# Get key: https://platform.deepseek.com/api_keys
# ------------------------------------------------------------
DEEPSEEK_API_KEY=sk-41dd0bbf135a4c50978eda493b7fdb5f
DEEPSEEK_MODEL=deepseek-chat

# ------------------------------------------------------------
# QWEN (Alibaba - FREE tier)
# Get key: https://dashscope.aliyun.com/
# ------------------------------------------------------------
QWEN_API_KEY=sk-e05edeaf57b8473fb1cde16119366bf8
QWEN_MODEL=qwen-max

# ------------------------------------------------------------
# OpenCode
# Get key: https://opencode.ai/workspace/
# ------------------------------------------------------------
OPENCODE_API_KEY=sk-8TErcGR4Rd4pZdUN42YDe9e3xl3iHmMfNabMf3rJ7zsAluahzPWpLBPmdDn7DkXA


# ------------------------------------------------------------
# OpenRouter
# Get key: https://openrouter.ai/workspaces/default/keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=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




# ------------------------------------------------------------
# TRANSLATION SETTINGS
# ------------------------------------------------------------
# Target language for translation
TARGET_LANGUAGE=Myanmar (Burmese)

# Source language (auto-detect if left as auto)
SOURCE_LANGUAGE=Chinese

# How many lines to translate per API call (chunk size)
CHUNK_SIZE=30

# Delay in seconds between API calls (avoid rate limiting)
REQUEST_DELAY=1

# Output folder for translated files
OUTPUT_DIR=translated
