# ⚠️ ENVIRONMENT VARIABLES - DO NOT COMMIT REAL API KEYS!
# This file contains EXAMPLE VALUES ONLY. Replace with your own keys.
# IMPORTANT: Add ".env" to your .gitignore before adding real keys!
#
# ── Web UI Security ───────────────────────────────────
# Optional: Set a custom secret key for Flask sessions
# If not set, a random key will be generated on each restart
# FLASK_SECRET_KEY=your_secure_random_key_here

# ── Model Selection ──────────────────────────────────
# Options: openrouter | gemini | ollama
AI_MODEL=ollama

# ── SSL Verification ─────────────────────────────────
# Set to 'false' ONLY if you have SSL certificate issues
# WARNING: Disabling SSL verification is insecure!
VERIFY_SSL=true

# ── OpenRouter (one key = many free models) ──────────
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── Google Gemini (AI Studio) ─────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
# Supported models: gemini-2.5-flash, gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (Local) ───────────────────────────────────
# Supported models:
#   - Qwen 3.5 (7B / 14B)     : qwen2.5:7b, qwen2.5:14b
#   - TranslateGemma          : translategemma, translategemma:12b
#   - Kimi K2.6 Cloud         : kimi-k2.6:cloud (via Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ── Chunking ──────────────────────────────────────────
MAX_CHUNK_CHARS=1000      # Characters per chunk (segmented translation!)

# ── Translation ───────────────────────────────────────
TARGET_LANGUAGE=Myanmar (Burmese)
SOURCE_LANGUAGE=Chinese
REQUEST_DELAY=1.0         # Seconds between API requests
                          # For Gemini: minimum 6.0s enforced (15 RPM limit, ~10 RPM safe)
                          # For OpenRouter: minimum 5.0s enforced (20 RPM limit, ~12 RPM safe)
                          # For Ollama: can use 0.0 (no rate limits)
                          # NOTE: System enforces minimums automatically for cloud APIs

# ── Quality ───────────────────────────────────────────
READABILITY_CHECK=true    # Enable readability report after assembly
